@{
    ViewData["Title"] = "Dashboard";
}

    <div class="row g-4">

        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <p class="text-muted mb-2 fw-bold fw-semibold">
                                Total Profit
                            </p>

                            <h3 class="fw-bold text-success mb-1">
                                ₹ @ViewBag.TotalProfit
                            </h3>

                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                                @ViewBag.GrowthPercentage %
                            </span>

                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-currency-rupee fs-3 text-success"></i>

                        </div>

                    </div>

                    <div class="mt-3">

                        <small class="text-muted fw-semibold">
                            @ViewBag.BusinessStatus
                        </small>

                    </div>

                </div>

            </div>

        </div>

        <!-- Total Orders -->
        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <p class="text-muted mb-2 fw-bold fw-semibold">
                                Total Orders
                            </p>

                            <h3 class="fw-bold text-primary mb-1">
                                @ViewBag.TotalSales
                            </h3>

                            <small class="text-muted">
                                Completed Orders
                            </small>

                        </div>

                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-cart-check fs-3 text-primary"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Customers -->
        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <p class="text-muted fw-bold mb-2 fw-semibold">
                                Customers
                            </p>

                            <h3 class="fw-bold text-warning mb-1">
                                @ViewBag.TotalCustomers
                            </h3>

                            <small class="text-muted">
                                Registered Customers
                            </small>

                        </div>

                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-people-fill fs-3 text-warning"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Sales Amount -->
        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                        <p class="text-muted mb-2 fw-bold fw-semibold">
                                Sales Amount
                            </p>

                            <h3 class="fw-bold text-danger mb-1">
                                ₹ @ViewBag.TotalSalesAmount
                            </h3>

                            <small class="text-muted">
                                Overall Revenue
                            </small>

                        </div>

                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle">

                            <i class="bi bi-bar-chart-line-fill fs-3 text-danger"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>