@model List<KiranaStoreUI.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<h2 class="mb-4 text-primary fw-bold">Categories</h2>

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" id="searchBox"
               placeholder="Search Categories..."
               class="form-control form-control-lg shadow-sm" />
    </div>

    <div class="col-md-8 text-end">
        <a asp-action="Create" class="btn btn-success btn-lg shadow">
            <i class="bi bi-plus-circle"></i> Add Category
        </a>
    </div>
</div>

<div class="row g-4" id="categoryContainer">
    @foreach (var item in Model)
    {
        <div class="col-md-3 col-sm-6 category-card">

            <div class="card shadow-sm border-0 rounded-4 category-click"
                 onclick="location.href='@Url.Action("All_productByID", new { id = item.CategoryId })'">

                <div class="card-body text-center">

                    <div class="mb-3">
                        <i class="bi bi-tags-fill text-warning"
                           style="font-size: 50px;"></i>
                    </div>

                    <h5 class="fw-bold">@item.CategoryName</h5>
                    <p class="text-muted">ID: @item.CategoryId</p>

                    <div class="mt-3 d-flex justify-content-center gap-2">

                        <!-- Details -->
                        <a asp-action="Details"
                           asp-route-id="@item.CategoryId"
                           class="btn btn-info btn-sm"
                           onclick="event.stopPropagation();">
                            <i class="bi bi-eye"></i>
                        </a>

                        <!-- Edit -->
                        <a asp-action="Edit"
                           asp-route-id="@item.CategoryId"
                           class="btn btn-warning btn-sm"
                           onclick="event.stopPropagation();">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <!-- Delete -->
                        <a asp-action="Delete"
                           asp-route-id="@item.CategoryId"
                           class="btn btn-danger btn-sm"
                           onclick="event.stopPropagation();">
                            <i class="bi bi-trash"></i>
                        </a>

                    </div>

                </div>
            </div>

        </div>
    }
</div>

<style>
    .category-click {
        transition: 0.25s ease-in-out;
        cursor: pointer;
    }

        .category-click:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

    #searchBox {
        border-radius: 8px;
        border: 1px solid #c9e6d2;
    }
</style>

<script>
    document.getElementById("searchBox").addEventListener("keyup", function () {
        var searchText = this.value.toLowerCase();
        var cards = document.querySelectorAll(".category-card");

        cards.forEach(function (card) {
            var text = card.innerText.toLowerCase();
            card.style.display = text.includes(searchText) ? "" : "none";
        });
    });
</script>
